# Shared with the website — used to derive the AES-256-GCM key for reply tokens.
MAIL_API_SECRET="your-mail-api-secret-here"

# Postgres connection string for the same database the website uses.
# The mail server reads aliases/recipients/domains and writes alias stats directly.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Upstash Redis Configuration (rate limiting; falls back to in-memory if unset)
UPSTASH_REDIS_REST_URL="https://example-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="example-token"

# Place your Let's Encrypt or other TLS certs in config/tls/
# cat privkey.pem cert.pem chain.pem > config/tls/anon.li.pem
TLS_CERT_PATH="config/tls/anon.li.pem"

# DKIM keys are stored in config/dkim/<domain>/private
# Generate with: ./scripts/generate-dkim.sh <domain>
# The script will output the DNS TXT record to add
# In Docker, these host-mounted keys are staged into a runtime directory so
# Haraka can read them without changing the host file permissions.
DKIM_REQUIRED_DOMAINS="anon.li reply.anon.li"

# Node environment
NODE_ENV="production"
LOG_LEVEL="info"
MAX_CONCURRENT_CONNECTIONS="10"
MAX_RECIPIENTS="100"
MAX_ERRORS="5"
